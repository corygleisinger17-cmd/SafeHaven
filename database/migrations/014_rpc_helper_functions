create or replace function public.require_authenticated_user()
returns uuid
language plpgsql
security definer
set search_path = pg_catalog, public
as $$
declare
    v_user_id uuid;
begin
    v_user_id := auth.uid();

    if v_user_id is null then
        raise exception using
            errcode='42501',
            message='Authentication is required.';
    end if;

    return v_user_id;
end;

create or replace function public.require_property_access(
    p_property_id uuid
)
returns void
language plpgsql
security definer
set search_path = pg_catalog, public
as $$
begin

    if p_property_id is null then
        raise exception using
            errcode='22004',
            message='Property ID is required.';
    end if;

    if not exists (
        select 1
        from public.properties
        where property_id = p_property_id
    ) then
        raise exception using
            errcode='P0002',
            message='Property not found.';
    end if;

    if not public.is_property_member(p_property_id) then
        raise exception using
            errcode='42501',
            message='You are not authorized to access this property.';
    end if;

end;
$$;

create or replace function public.require_household_owner(
    p_household_id uuid
)
returns void
language plpgsql
security definer
set search_path = pg_catalog, public
as $$
begin

    if not public.is_household_owner(p_household_id) then
        raise exception using
            errcode='42501',
            message='Household owner privileges are required.';
    end if;

end;
$$;


create or replace function public.require_household_admin(
    p_household_id uuid
)
returns void
language plpgsql
security definer
set search_path = pg_catalog, public
as $$
begin

    if not exists (
        select 1
        from public.household_members
        where household_id = p_household_id
          and user_id = auth.uid()
          and invite_status='accepted'
          and role in ('owner','admin')
    ) then
        raise exception using
            errcode='42501',
            message='Household administrator privileges are required.';
    end if;

end;
$$;



$$;
