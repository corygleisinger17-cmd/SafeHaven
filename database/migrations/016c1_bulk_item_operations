        else
          v_unique_count || ' items restored successfully.'
      end,
    'operation', 'bulk_restore',
    'requested_count', v_requested_count,
    'processed_count', v_unique_count,
    'duplicate_ids_removed',
      v_requested_count - v_unique_count,
    'data', v_results
  );
end;
$$;


-- ============================================================
-- 4. FUNCTION PERMISSIONS
-- ============================================================

revoke all on function public.bulk_move_items(
  uuid[],
  uuid,
  uuid
) from public;

revoke all on function public.bulk_soft_delete_items(
  uuid[]
) from public;

revoke all on function public.bulk_restore_items(
  uuid[]
) from public;


grant execute on function public.bulk_move_items(
  uuid[],
  uuid,
  uuid
) to authenticated;

grant execute on function public.bulk_soft_delete_items(
  uuid[]
) to authenticated;

grant execute on function public.bulk_restore_items(
  uuid[]
) to authenticated;


commit;
